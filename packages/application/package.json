{
  "name": "@hivork/application",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ports": {
      "types": "./dist/ports/index.d.ts",
      "default": "./dist/ports/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@hivork/contracts": "workspace:*",
    "@hivork/domain": "workspace:*",
    "@hivork/i18n": "workspace:*",
    "exceljs": "^4.4.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@hivork/config": "workspace:*",
    "@hivork/infrastructure": "workspace:*",
    "@types/node": "^22.15.32",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
