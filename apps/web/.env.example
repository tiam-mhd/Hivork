# @hivork/web — environment variables (subset)
#
# Source of truth: ../../.env.example (repo root)
#
# Required:
#   NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
#   WEB_PORT=3000 (dev script uses --port 3000)
#
# Captcha widget (IFP-012 — must match API CAPTCHA_SITE_KEY when enabled):
#   NEXT_PUBLIC_CAPTCHA_ENABLED=false
#   NEXT_PUBLIC_CAPTCHA_SITE_KEY=
