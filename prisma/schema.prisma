  PLEDGED
  RELEASED
  FORFEITED

  @@map("collateral_status")
}

model ContractCollateral {
  id                 String           @id @default(uuid()) @db.Uuid
  tenantId           String           @map("tenant_id") @db.Uuid
  saleId             String           @map("sale_id") @db.Uuid
