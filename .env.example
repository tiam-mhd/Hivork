# =============================================================================
# Hivork — environment template (TASK-005)
#
# Setup:
#   cp .env.example .env
#
# Rules:
#   - Never commit .env with real secrets
#   - Apps may use root .env or app-specific .env.local (see apps/*/README)
# =============================================================================

# --- App ---
# Runtime environment
NODE_ENV=development
# Public URLs (browser / server-side fetch)
APP_URL=http://localhost:3000
API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# Dev server ports (TASK-006 api:4000, TASK-007 web:3000)
WEB_PORT=3000
API_PORT=4000
BOT_GATEWAY_PORT=4001
SCHEDULER_PORT=4002

# --- Database (docker compose — TASK-002) ---
DATABASE_URL=postgresql://hivork:hivork_dev@127.0.0.1:5432/hivork?schema=public

# --- Redis (docker compose — TASK-002) ---
# OTP storage, rate limits, BullMQ
REDIS_URL=redis://localhost:6379

# --- Auth / JWT ---
# Min 32 chars in production — generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_REFRESH_SESSION_TTL=24h

# Captcha (Cloudflare Turnstile — IFP-012)
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET_KEY=
CAPTCHA_SITE_KEY=
CAPTCHA_BYPASS_TOKEN=test-bypass

# --- IP allowlist (IFP-014) ---
# Internal support bypass header: X-Ip-Allowlist-Bypass
IP_ALLOWLIST_BYPASS_TOKEN=
# Express trust proxy hops for X-Forwarded-For (req.ip)
TRUSTED_PROXY_HOPS=1

# --- OTP ---
OTP_TTL_SECONDS=120
OTP_RATE_LIMIT_PER_MINUTE=3

# --- MFA / TOTP (IFP-005) ---
# AES-256-GCM key — generate with: openssl rand -base64 32
MFA_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# dev: console (log only) | mailhog (SMTP below) | kavenegar (production)
SMS_PROVIDER=console
KAVENEGAR_API_KEY=

# Mailhog SMTP (dev — TASK-002, UI http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025

# --- Telegram (phase 2 — bot-gateway) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=dev

# --- Bale (phase 2+ — bot-gateway) ---
BALE_BOT_TOKEN=
BALE_WEBHOOK_SECRET=

# --- Logging ---
# debug | info | warn | error
LOG_LEVEL=debug

# --- Export (IFP-TASK-025 / IFP-TASK-026) ---
EXPORT_MAX_ROWS=50000
PDF_MAX_ROWS=500

# --- CORS (api — TASK-006) ---
CORS_ORIGIN=http://localhost:3000

# --- Seed data (TASK-028 — db:seed) ---
SEED_PLATFORM_ADMIN_PHONE=09120000001
SEED_OWNER_PHONE=09120000000
SEED_DEMO_PASSWORD=DemoPass1
SEED_DEMO_PASSWORD=DemoPass1
